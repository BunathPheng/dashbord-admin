# Mock mode - Set to true to use mock data (no database needed). Login: admin@admin.com / admin123
USE_MOCK_DATA=true

# NextAuth - Required when not in mock mode. For mock mode, a default is used.
AUTH_SECRET=your-secret-key-here

# NextAuth URL - Your app URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# PostgreSQL - Not needed when USE_MOCK_DATA=true. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/yourdb
